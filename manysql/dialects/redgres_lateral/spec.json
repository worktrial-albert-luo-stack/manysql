{
  "description": "Redshift-Postgres hybrid requiring LATERAL for correlated FROM subqueries, MATCHING instead of USING, CONCAT_WS-only string concatenation, and reversed EXCEPT/INTERSECT precedence binding tighter than UNION.",
  "divergence_level": "moderate",
  "inspired_by": [
    "redshift",
    "postgres",
    "bigquery"
  ],
  "name": "redgres_lateral",
  "notes": "Hybrid of Redshift's LATERAL-heavy correlated subquery style with Postgres semantics. Key divergences: (1) CONCAT_WS is the only string concatenation mechanism\u2014bare || is not supported; (2) LATERAL keyword is mandatory in JOIN keywords for inner and cross joins; (3) EXCEPT and INTERSECT bind tighter than UNION (reversed from standard SQL precedence); (4) window default frame is ROWS UNBOUNDED TO CURRENT rather than RANGE; (5) requires semicolon terminator. Conflicts with snowacle_qualify on row-limiting (LIMIT vs QUALIFY), null ordering (contextual vs immutable global), CTE keyword (WITH vs DEFINE), and concat mechanism.",
  "semantic_overrides": {
    "array_base_index": 1,
    "boolean_truthiness": "strict",
    "count_distinct_null": "excluded",
    "division_by_zero": "error",
    "group_by_accepts_select_aliases": false,
    "identifier_case_fold": "lower",
    "ilike_supported": true,
    "integer_division": "truncate",
    "like_case_sensitive": true,
    "null_order_default_asc": "last",
    "null_order_default_desc": "first",
    "null_safe_eq_supported": true,
    "quoted_identifiers_case_sensitive": true,
    "select_resolves_through_group_by": false,
    "set_op_default": "distinct",
    "string_concat_op": "CONCAT_only",
    "sum_of_empty_returns_null": true,
    "window_default_frame": "rows_unbounded_to_current"
  },
