# Copy this file to .env and fill in your keys. .env is gitignored.

# Used by both the codegen LLM client and the eval harness.
# Either or both can be set.
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional: override default codegen model. Defaults baked into manysql/codegen/llm_client.py.
# MANYSQL_CODEGEN_MODEL=anthropic/claude-sonnet-4
# MANYSQL_CODEGEN_PROVIDER=openrouter  # or "openai"

# Eval harness: optional vLLM serve endpoint (used when --provider vllm).
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_API_KEY=

# Eval harness: optional Tinybird backend (used when --backend tinybird).
# TINYBIRD_API_HOST=https://api.tinybird.co
# TINYBIRD_WORKSPACE_TOKEN=

# Training: Weights & Biases logging for train/grpo_gsm8k.py. If set, the
# GRPO trainer automatically logs reward curves and losses. Leave unset
# (or pass --no-wandb) to disable.
# WANDB_API_KEY=
