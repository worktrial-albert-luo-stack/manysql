{
  "description": "MySQL-flavored moderate dialect: backtick identifiers, LIMIT without OFFSET keyword, loose boolean truthiness, CONCAT-only string joining, and case-insensitive LIKE.",
  "divergence_level": "moderate",
  "inspired_by": [
    "mysql"
  ],
  "name": "moderate_mysql_loose",
  "notes": "Captures MySQL's most distinctive quirks: backtick quoting, <=> null-safe equality, CONVERT()-style casts, CONCAT-only string joining (|| is not concat), c-style boolean truthiness where 0/1 freely coerce, case-insensitive LIKE by default, and GROUP BY accepting SELECT aliases. The required semicolon terminator mirrors mysql CLI behavior.",
  "semantic_overrides": {
    "boolean_truthiness": "c_style",
    "count_distinct_null": "excluded",
    "division_by_zero": "null",
    "group_by_accepts_select_aliases": true,
    "identifier_case_fold": "preserve",
    "ilike_supported": false,
    "integer_division": "truncate",
    "like_case_sensitive": false,
    "null_order_default_asc": "first",
    "null_order_default_desc": "last",
    "null_safe_eq_supported": true,
    "quoted_identifiers_case_sensitive": false,
    "select_resolves_through_group_by": false,
    "set_op_default": "distinct",
    "string_concat_op": "CONCAT_only",
    "sum_of_empty_returns_null": true,
    "window_default_frame": "range_unbounded_to_current"
  },
